DAFNY_VERIFY_TIMEOUT_SEC=30
COMPILE_TIMEOUT_SEC=180

# --- Agent sandbox (see research_loop/AGENT_SANDBOX.md) ---
# 0 = local subprocess (default); 1 = Docker container
USE_AGENT_DOCKER=0
AGENT_IMAGE=verified-hillclimbing-agent:latest
AGENT_TIMEOUT_SEC=600

# Pipeline logging: OFF | ERROR | WARN | INFO | DEBUG | TRACE (debug/ops → stderr)
HILLCLIMBING_LOG_LEVEL=INFO

# Demo UI: off in production. Enable via scripts/demo.sh (sets HILLCLIMBING_DEMO=1).

# Default: Cursor Agent CLI with Composer 2.5 (reads prompt from PROMPT.txt in workspace).
AGENT_CMD=agent -p --force --model composer-2.5 "$(cat PROMPT.txt)"
AGENT_ENV=CURSOR_API_KEY

# Alternatives (uncomment one AGENT_CMD + matching AGENT_ENV):
# AGENT_CMD=agy -p "$(cat PROMPT.txt)"
# AGENT_ENV=GEMINI_API_KEY,GOOGLE_API_KEY
#
# AGENT_CMD=claude -p "$(cat PROMPT.txt)"
# AGENT_ENV=ANTHROPIC_API_KEY
#
# AGENT_CMD=codex exec "$(cat PROMPT.txt)"
# AGENT_ENV=OPENAI_API_KEY
#
# AGENT_CMD=opencode run "$(cat PROMPT.txt)"
# AGENT_ENV=OPENCODE_API_KEY,ANTHROPIC_API_KEY,OPENAI_API_KEY
#
# AGENT_CMD=pi -p "$(cat PROMPT.txt)"
# AGENT_ENV=ANTHROPIC_API_KEY,OPENAI_API_KEY
